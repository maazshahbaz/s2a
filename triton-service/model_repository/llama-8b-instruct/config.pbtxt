name: "llama-8b-instruct"
backend: "python"
max_batch_size: 1

input [
  {
    name: "prompt"
    data_type: TYPE_STRING
    dims: [ 1 ]
  },
  {
    name: "max_tokens"
    data_type: TYPE_INT32
    dims: [ 1 ]
    optional: true
  },
  {
    name: "temperature"
    data_type: TYPE_FP32
    dims: [ 1 ]
    optional: true
  },
  {
    name: "top_p"
    data_type: TYPE_FP32
    dims: [ 1 ]
    optional: true
  },
  {
    name: "top_k"
    data_type: TYPE_INT32
    dims: [ 1 ]
    optional: true
  },
  {
    name: "system_prompt"
    data_type: TYPE_STRING
    dims: [ 1 ]
    optional: true
  }
]

output [
  {
    name: "generated_text"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

instance_group [
  {
    count: 2
    kind: KIND_GPU
    gpus: [ 0 ]
  }
]

# Model-specific parameters
parameters: {
  key: "model_name"
  value: {
    string_value: "meta-llama/Meta-Llama-3.1-8B-Instruct"
  }
}

parameters: {
  key: "default_max_tokens"
  value: {
    string_value: "512"
  }
}

parameters: {
  key: "default_temperature"
  value: {
    string_value: "0.7"
  }
}

parameters: {
  key: "default_top_p"
  value: {
    string_value: "0.9"
  }
}

parameters: {
  key: "default_top_k"
  value: {
    string_value: "50"
  }
}

# Performance optimizations
# Set to "true" to enable Flash Attention 2 (requires flash-attn package)
parameters: {
  key: "use_flash_attention"
  value: {
    string_value: "false"
  }
}

# Set to "true" to load model in 8-bit mode (saves memory but slower)
parameters: {
  key: "load_in_8bit"
  value: {
    string_value: "True"
  }
}


dynamic_batching {
 # preferred_batch_size: [ 2, 4 ]
  max_queue_delay_microseconds: 1000
}

