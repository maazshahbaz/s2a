name: "streaming_asr"
backend: "python"
max_batch_size: 1

input [
  {
    name: "audio_data"
    data_type: TYPE_FP32
    dims: [ -1 ]
  },
  {
    name: "sample_rate"
    data_type: TYPE_INT32
    dims: [ 1 ]
  },
  {
    name: "session_id"
    data_type: TYPE_STRING
    dims: [ 1 ]
  },
  {
    name: "is_final"
    data_type: TYPE_BOOL
    dims: [ 1 ]
  }
]

output [
  {
    name: "transcription"
    data_type: TYPE_STRING
    dims: [ 1 ]
  }
]

instance_group [
  {
    count: 2
    kind: KIND_GPU
    gpus: [ 0 ]
  }
]

dynamic_batching {
  max_queue_delay_microseconds: 500
  preferred_batch_size: [ 1 ]
}
