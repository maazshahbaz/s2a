# Custom vLLM Dockerfile for S2A Intelligence Integration
FROM vllm/vllm-openai:latest

# Set working directory
WORKDIR /app

# Install additional dependencies for S2A integration
RUN pip install --no-cache-dir \
    httpx \
    loguru \
    prometheus-client \
    redis

# Create directories
RUN mkdir -p /models /logs /cache

# Set environment variables
ENV MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
ENV DTYPE=bfloat16
ENV MAX_MODEL_LEN=16000
ENV GPU_MEMORY_UTILIZATION=0.5
ENV TRUST_REMOTE_CODE=true
ENV PORT=8000
ENV HOST=0.0.0.0
ENV MAX_NUM_SEQS=256
ENV TENSOR_PARALLEL_SIZE=1

# Copy custom configuration and monitoring scripts
COPY ./vllm-config/startup.sh /app/startup.sh
COPY ./vllm-config/health-check.py /app/health-check.py
COPY ./vllm-config/metrics.py /app/metrics.py

# Make scripts executable
RUN chmod +x /app/startup.sh

# Create non-root user for security
RUN groupadd -r vllm && useradd -r -g vllm vllm
RUN chown -R vllm:vllm /app /models /logs /cache
USER vllm

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=180s --retries=5 \
    CMD python /app/health-check.py

# Expose port
EXPOSE 8000

# Start vLLM with custom configuration
CMD ["/app/startup.sh"]