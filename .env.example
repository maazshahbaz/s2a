# S2A Speech-to-Actions Configuration
# Copy this file to .env and customize for your environment

# ====================
# ASR CONFIGURATION  
# ====================

# Model settings
S2A_MODEL_NAME=nvidia/parakeet-tdt-0.6b-v2
S2A_DEVICE=cuda
S2A_BATCH_SIZE=4
S2A_GPU_MEMORY_FRACTION=0.8
S2A_ENABLE_MIXED_PRECISION=true

# Audio processing
S2A_MAX_CHUNK_DURATION=1440
S2A_MIN_AUDIO_DURATION=5.0
S2A_TARGET_SAMPLE_RATE=16000

# API settings
S2A_API_HOST=0.0.0.0
S2A_API_PORT=8001
S2A_LOG_LEVEL=INFO

# Streaming
S2A_STREAMING_MAX_CONCURRENT_SESSIONS=50
S2A_STREAMING_CHUNK_DURATION=1.0
S2A_STREAMING_AUDIOSOCKET_PORT=8003
S2A_STREAMING_SESSION_START_TIMEOUT_SECONDS=15.0
S2A_STREAMING_IDLE_TIMEOUT_SECONDS=30.0
S2A_STREAMING_MAX_SESSION_DURATION_SECONDS=14400
S2A_STREAMING_MAX_BYTES_PER_SECOND=64000
S2A_STREAMING_MAX_FRAME_BYTES=32768
S2A_STREAMING_INFERENCE_TIMEOUT_SECONDS=20.0
# Optional defaults/hardening
# S2A_STREAMING_DEFAULT_CALLBACK_URL=https://your-callback-endpoint/path
# S2A_STREAMING_ALLOWED_IPS=10.0.0.0/8,192.168.1.10

# ====================
# AUTHENTICATION
# ====================

# API Key management
API_KEY_SECRET=your-super-secure-secret-key-here-min-32-characters

# ====================
# PERFORMANCE MONITORING
# ====================

S2A_PERF_ENABLE_METRICS=true
S2A_PERF_METRICS_INTERVAL=10.0
S2A_PERF_RTF_WARNING_THRESHOLD=0.5
S2A_PERF_RTF_ERROR_THRESHOLD=1.0
