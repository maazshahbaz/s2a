# S2A Speech-to-Actions Configuration
# Copy this file to .env and customize for your environment

# ====================
# ASR CONFIGURATION  
# ====================

# Model settings
S2A_MODEL_NAME=nvidia/parakeet-tdt-0.6b-v2
S2A_DEVICE=cuda
S2A_BATCH_SIZE=4
S2A_GPU_MEMORY_FRACTION=0.8
S2A_ENABLE_MIXED_PRECISION=true

# Audio processing
S2A_MAX_CHUNK_DURATION=1440
S2A_MIN_AUDIO_DURATION=5.0
S2A_TARGET_SAMPLE_RATE=16000
S2A_VAD_AGGRESSIVENESS=3

# API settings
S2A_API_HOST=0.0.0.0
S2A_API_PORT=8001
S2A_LOG_LEVEL=INFO

# Batch processing
S2A_MAX_QUEUE_SIZE=100
S2A_NUM_WORKERS=2
S2A_DYNAMIC_BATCHING=true

# Streaming
S2A_STREAMING_MAX_CONCURRENT_SESSIONS=50
S2A_STREAMING_CHUNK_DURATION=1.0
S2A_STREAMING_AUDIOSOCKET_PORT=8003
S2A_STREAMING_SESSION_START_TIMEOUT_SECONDS=15.0
S2A_STREAMING_IDLE_TIMEOUT_SECONDS=30.0
S2A_STREAMING_MAX_SESSION_DURATION_SECONDS=14400
S2A_STREAMING_MAX_BYTES_PER_SECOND=64000
S2A_STREAMING_MAX_FRAME_BYTES=32768
# Optional defaults/hardening
# S2A_STREAMING_DEFAULT_CALLBACK_URL=https://your-callback-endpoint/path
# S2A_STREAMING_ALLOWED_IPS=10.0.0.0/8,192.168.1.10

# ====================
# INTELLIGENCE CONFIGURATION
# ====================

# Core intelligence settings
S2A_INTEL_ENABLED=true
S2A_INTEL_VLLM_BASE_URL=http://localhost:8000/v1
S2A_INTEL_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# LLM parameters
S2A_INTEL_TEMPERATURE=0.2
S2A_INTEL_MAX_TOKENS=500
S2A_INTEL_TOP_P=0.9
S2A_INTEL_TIMEOUT_SECONDS=30.0

# GPU memory (when co-located with ASR)
S2A_INTEL_GPU_MEMORY_UTILIZATION=0.6
S2A_INTEL_MAX_MODEL_LEN=16000

# Processing behavior
S2A_INTEL_AUTO_PROCESS=true
S2A_INTEL_RETRY_ATTEMPTS=2
S2A_INTEL_BATCH_PROCESSING=true
S2A_INTEL_MAX_BATCH_SIZE=8

# Queue settings
S2A_INTEL_QUEUE_MAX_SIZE=200
S2A_INTEL_PROCESSING_TIMEOUT=600.0
S2A_INTEL_QUEUE_CHECK_INTERVAL=5.0

# Output settings
S2A_INTEL_SAVE_RAW_RESPONSES=false
S2A_INTEL_CONFIDENCE_THRESHOLD=0.6

# Integration
S2A_INTEL_WEBHOOK_INTELLIGENCE_ENABLED=true
S2A_INTEL_STORAGE_ENABLED=true

# ====================
# INTELLIGENCE METRICS
# ====================

# Metrics collection
S2A_INTEL_METRICS_ENABLE_METRICS=true
S2A_INTEL_METRICS_METRICS_INTERVAL=15.0

# Performance thresholds
S2A_INTEL_METRICS_EXTRACTION_LATENCY_WARNING=5.0
S2A_INTEL_METRICS_EXTRACTION_LATENCY_ERROR=15.0

# Success rate monitoring
S2A_INTEL_METRICS_SUCCESS_RATE_WARNING=0.7
S2A_INTEL_METRICS_SUCCESS_RATE_ERROR=0.5

# Queue monitoring
S2A_INTEL_METRICS_QUEUE_WARNING_THRESHOLD=100
S2A_INTEL_METRICS_QUEUE_ERROR_THRESHOLD=150

# Field extraction rates
S2A_INTEL_METRICS_FIELD_HIT_RATE_WARNING=0.4

# ====================
# AUTHENTICATION
# ====================

# API Key management
API_KEY_SECRET=your-super-secure-secret-key-here-min-32-characters
API_KEYS_FILE=./api_keys.json

# ====================
# PERFORMANCE MONITORING
# ====================

S2A_PERF_ENABLE_METRICS=true
S2A_PERF_METRICS_INTERVAL=10.0
S2A_PERF_RTF_WARNING_THRESHOLD=0.5
S2A_PERF_RTF_ERROR_THRESHOLD=1.0
